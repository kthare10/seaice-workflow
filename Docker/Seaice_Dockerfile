FROM python:3.10-slim

# Install system dependencies
RUN apt-get update && \
    apt-get install -y git wget curl openssh-client build-essential \
    libgdal-dev gdal-bin libhdf5-dev libproj-dev libgeos-dev && \
    rm -rf /var/lib/apt/lists/*

# Install Python dependencies
RUN pip install --no-cache-dir \
    numpy \
    pandas \
    scipy \
    scikit-learn \
    h5py \
    tensorflow \
    matplotlib \
    rasterio \
    pyproj \
    cartopy \
    earthaccess \
    planetary-computer \
    pystac-client

# Set working directory
WORKDIR /app

# Set Python to not buffer output
ENV PYTHONUNBUFFERED=1

# Create output directory
RUN mkdir -p /app/output

# Default command
CMD ["/bin/bash"]
